{
  "appId": "com.mediapurge.app",
  "productName": "MediaPurge",
  "directories": {
    "output": "dist-build"
  },
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "asar": true,
  "win": {
    "target": "nsis"
  },
  "nsis": {
    "oneClick": true,
    "allowToChangeInstallationDirectory": false,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  }
}
