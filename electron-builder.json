{
  "appId": "com.galleo.app",
  "productName": "Galleo",
  "directories": {
    "output": "dist-build"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "package.json"
  ],
  "asar": true,
  "win": {
    "target": "nsis",
    "icon": "build/icon.ico"
  },
  "mac": {
    "target": "dmg",
    "icon": "build/icon.png"
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "icon": "build/icon.png",
    "maintainer": "Manovihar Sirimalla <sirimallamanovihar@outlook.com>"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "installerSidebar": "build/installerSidebar.bmp",
    "installerHeader": "build/installerHeader.bmp",
    "include": "build/installer.nsh"
  }
}
